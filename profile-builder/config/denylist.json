{
  "patterns": [
    { "name": "email",            "regex": "[\\w.+-]+@[\\w.-]+\\.[A-Za-z]{2,}" },
    { "name": "slack_channel_id", "regex": "\\bC[0-9A-Z]{8,}\\b" },
    { "name": "slack_user_id",    "regex": "\\bU[0-9A-Z]{8,}\\b" },
    { "name": "jira_key",         "regex": "\\b(RNR|PROJ|RTB|RSMS|MNG)-\\d+\\b" },
    { "name": "ipv4",             "regex": "\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b" },
    { "name": "aws_access_key",   "regex": "AKIA[0-9A-Z]{16}" },
    { "name": "bearer_token",     "regex": "bearer\\s+[A-Za-z0-9._-]{20,}" },
    { "name": "github_token",     "regex": "ghp_[A-Za-z0-9]{30,}" },
    { "name": "internal_subdomain", "regex": "[\\w-]+\\.(rsquareon|internal|corp)\\.[A-Za-z]{2,}" }
  ]
}
